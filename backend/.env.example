# Atlas AI Command Center - Environment Template
# Copy to .env and fill in values

# Database (SQLite async)
DATABASE_URL=sqlite+aiosqlite:///./academic.db

# JWT (generate a long random string for production)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=Atlas AI Command Center
DEBUG=false

# AI - Groq (for academic analysis)
GROQ_API_KEY=
